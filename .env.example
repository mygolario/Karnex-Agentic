# =============================================================================
# Karnex environment template — copy to .env and fill placeholders
# Run: .\scripts\setup-env.ps1  (creates .env + syncs Python vars + web symlink)
# NEVER commit real secrets here. Use .env (gitignored) for actual values.
# =============================================================================

# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_URL=your_supabase_url_here
# Railway agent API: legacy HS256 secret; ES256 sessions use JWKS from SUPABASE_URL
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# OxaPay (https://oxapay.com merchant dashboard)
OXAPAY_MERCHANT_API_KEY=your_merchant_api_key_here
NEXT_PUBLIC_OXAPAY_CALLBACK_URL=http://localhost:3000/api/webhooks/oxapay
NEXT_PUBLIC_OXAPAY_SANDBOX=true
# Production: https://your-app.vercel.app/api/webhooks/oxapay
# Dev webhooks: ngrok http 3000 → use ngrok URL + /api/webhooks/oxapay

# [v2 - deferred] Stripe - not in v1
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_pub_key_here

# AI & LLM (Railway agent service; OpenRouter required for agents)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: cap completion tokens (default 8192; avoids OpenRouter 402 on low balance)
# OPENROUTER_MAX_TOKENS=8192
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com

# Integrations (optional until feature is enabled)
GITHUB_APP_ID=your_github_app_id
# PEM on one line with \n between lines, or use multiline quoted block in .env
GITHUB_PRIVATE_KEY=your_github_private_key_pem_here
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
RESEND_API_KEY=your_resend_api_key_here
POSTHOG_API_KEY=your_posthog_personal_api_key_here
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_project_token_here
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Service URLs — local dev defaults
AGENT_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional legacy browser URL (must include https:// if pointing at Railway):
# NEXT_PUBLIC_AGENT_SERVICE_URL=http://localhost:8000

# Production examples (set on Vercel / Railway, not in this file):
# AGENT_SERVICE_URL=https://your-agent.up.railway.app
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Python agent service (Railway / local uvicorn)
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3080
KARNEX_WEB_ORIGIN=http://localhost:3000
AGENT_SERVICE_INTERNAL_KEY=dev-internal-key
