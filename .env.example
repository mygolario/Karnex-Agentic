# Supabase Config
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# OxaPay Config
OXAPAY_MERCHANT_API_KEY=your_merchant_api_key_here
NEXT_PUBLIC_OXAPAY_CALLBACK_URL=https://your-domain.com/api/webhooks/oxapay
NEXT_PUBLIC_OXAPAY_SANDBOX=true

# Dev only (ngrok)
# NEXT_PUBLIC_OXAPAY_CALLBACK_URL=https://your-ngrok-id.ngrok.io/api/webhooks/oxapay

# [v2 - deferred] Stripe - not in v1
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_pub_key_here

# AI & LLM Config
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=false

# Integrations
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY=your_github_private_key
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
RESEND_API_KEY=your_resend_api_key_here
POSTHOG_API_KEY=your_posthog_api_key
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_public_key

# Service URLs
AGENT_SERVICE_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
